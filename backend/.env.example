APP_NAME=FintechTracker
APP_ENV=local
# Use this key so the site works when you copy .env.example to .env on the server. For production you can run: php artisan key:generate
APP_KEY=base64:+zczpiIsTLTnJopUFIstp/mhOGv4Zf1Zp9BrPO5XWWE=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Local: SQLite (create database/database.sqlite then run: php artisan migrate)
DB_CONNECTION=sqlite
# DB_DATABASE= optional; defaults to database/database.sqlite

# Hostinger / williamhq.com: MySQL (set these on the server only; never commit .env)
# DB_CONNECTION=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=u752162317_hq
# DB_USERNAME=u752162317_hq
# DB_PASSWORD=your_mysql_password_here

# Or use PostgreSQL:
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=fintech_tracker
# DB_USERNAME=fintech
# DB_PASSWORD=secret

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
QUEUE_CONNECTION=redis

CACHE_STORE=redis
SESSION_DRIVER=database

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

OPENAI_API_KEY=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=
