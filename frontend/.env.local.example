# Optional: set only if the API is on a different origin. Leave empty for same-origin /api.
NEXT_PUBLIC_API_URL=

# Database (MySQL) - used by Prisma
DATABASE_URL="mysql://user:password@localhost:3306/hq"

# NextAuth
NEXTAUTH_SECRET=your-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3001

# App base URL for emails (password reset, invites)
NEXT_PUBLIC_APP_URL=http://localhost:3001
