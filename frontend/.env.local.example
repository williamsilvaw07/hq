# Optional: set only if the API is on a different origin. Leave empty for same-origin /api.
NEXT_PUBLIC_API_URL=

# Database (MySQL) - use either DATABASE_URL or the DB_* variables below
DATABASE_URL="mysql://user:password@localhost:3306/hq"

# Or set these (e.g. in Hostinger env vars):
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_NAME=your_db_name

# NextAuth
NEXTAUTH_SECRET=your-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3001

# App base URL for emails (password reset, invites)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# WhatsApp Cloud API (Meta)
WHATSAPP_VERIFY_TOKEN=your-random-verify-token
WHATSAPP_ACCESS_TOKEN=your-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
META_APP_SECRET=your-meta-app-secret
